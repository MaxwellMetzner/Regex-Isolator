{
  "name": "regex-isolator-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1420",
    "build": "tsc && vite build",
    "build:icons": "powershell -ExecutionPolicy Bypass -File ./scripts/generate-icons.ps1",
    "build:portable": "powershell -ExecutionPolicy Bypass -File ./scripts/build-portable.ps1",
    "build:portable:signed": "powershell -ExecutionPolicy Bypass -File ./scripts/build-portable.ps1 -Sign",
    "build:installer:nsis": "tauri build --bundles nsis",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
