{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Regex Isolator Desktop",
  "version": "0.1.0",
  "identifier": "com.maxwellmetzner.regexisolator.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "Maxwell Metzner",
    "copyright": "Copyright (c) Maxwell Metzner",
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Regex Isolator Desktop",
        "width": 1440,
        "height": 920,
        "minWidth": 1140,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
